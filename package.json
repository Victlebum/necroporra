{
  "name": "necroporra",
  "version": "1.0.0",
  "description": "Dead pool application with Django and Bulma",
  "scripts": {
    "build:css": "sass --load-path=node_modules necroporra/static/necroporra/scss/custom.scss necroporra/static/necroporra/css/styles.css",
    "watch:css": "sass --load-path=node_modules --watch necroporra/static/necroporra/scss/custom.scss necroporra/static/necroporra/css/styles.css"
  },
  "dependencies": {
    "bulma": "^1.0.0"
  },
  "devDependencies": {
    "sass": "^1.69.0"
  }
}
